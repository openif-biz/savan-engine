    {
      "node_id": "V_PROCESS_4",
      "name": "優先順位設定",
      "type": "phase",
      "parent": "V_PROCESS",
      "attributes": {
        "focus": [
          "経済効果度",
          "緊急度",
          "難易度"
        ]
      }
    },
    {
      "node_id": "V_PROCESS_5",
      "name": "実行計画",
      "type": "phase",
      "parent": "V_PROCESS",
