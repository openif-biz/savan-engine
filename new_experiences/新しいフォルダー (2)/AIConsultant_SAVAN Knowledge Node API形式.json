      "description": "全体最適思考。組織の方向性・価値観を俯瞰して示唆",
      "children": [
        "H_BASIC_1",
        "H_BASIC_2"
      ]
    },
    {
      "node_id": "H_BASIC_1",
      "name": "経営戦略",
      "type": "strategy",
      "parent": "H_BASIC",
      "attributes": {
